services:
  api:
    image: ghcr.io/atvirokodosprendimai/mailservice-api:latest
    environment:
      HTTP_ADDR: ":8080"
      DATABASE_DSN: /data/mailservice.db
      PUBLIC_BASE_URL: http://localhost:8080
      MAIL_DOMAIN: mail.local
      IMAP_HOST: mail.local
      IMAP_PORT: "143"
      MAX_CONCURRENT_REQUESTS: "100"
      POLAR_TOKEN: ""
      POLAR_PRODUCT_ID: ""
      POLAR_SERVER_URL: https://api.polar.sh
      POLAR_SUCCESS_URL: http://localhost:8080/v1/payments/polar/success?checkout_id={CHECKOUT_ID}
      POLAR_RETURN_URL: http://localhost:8080
      STRIPE_SECRET_KEY: ""
      STRIPE_WEBHOOK_SECRET: ""
      STRIPE_SUCCESS_URL: http://localhost:8080/payment/success
      STRIPE_CANCEL_URL: http://localhost:8080/payment/cancel
      STRIPE_CURRENCY: usd
      MAILBOX_PRICE_CENTS: "299"
    volumes:
      - shared_db:/data
    ports:
      - "8080:8080"
    restart: unless-stopped

  mailreceive:
    image: ghcr.io/atvirokodosprendimai/mailservice-mailreceive:latest
    environment:
      MAIL_DB_PATH: /data/mailservice.db
      MAIL_DOMAIN: mail.local
      MAIL_DEBUG: "1"
      MAILBOX_USER: ""
      MAILBOX_PASSWORD: ""
    volumes:
      - shared_db:/data
      - mail_vhosts:/var/mail/vhosts
    ports:
      - "25:25"
      - "143:143"
    restart: unless-stopped

volumes:
  shared_db:
  mail_vhosts:
