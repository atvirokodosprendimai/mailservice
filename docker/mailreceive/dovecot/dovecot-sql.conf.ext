driver = sqlite
connect = /var/lib/mail/shared-mailservice.db
default_pass_scheme = PLAIN
password_query = SELECT email AS user, password FROM mail_users WHERE enabled=1 AND (email='%u' OR login='%n')
user_query = SELECT '/var/mail/vhosts/' || maildir || '/Maildir' AS home, 5000 AS uid, 5000 AS gid FROM mail_users WHERE enabled=1 AND (email='%u' OR login='%n')
