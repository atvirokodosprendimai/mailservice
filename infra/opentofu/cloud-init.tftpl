#cloud-config
package_update: true
packages:
  - docker.io
  - docker-compose-plugin

write_files:
  - path: /etc/mailservice/bootstrap.env
    permissions: "0644"
    content: |
      PUBLIC_BASE_URL=${public_base_url}

runcmd:
  - systemctl enable docker
  - systemctl start docker
  - mkdir -p /opt/mailservice
