HTTP_ADDR=:8080
DATABASE_DSN=mailservice.db
MAX_CONCURRENT_REQUESTS=100
BUILD_NUMBER=dev
CACHE_BUSTER=
PUBLIC_BASE_URL=http://localhost:8080
MAIL_DOMAIN=mail.local
IMAP_HOST=mail.local
IMAP_PORT=143

# EdProof challenge-response HMAC secret.
# Required for secure key ownership verification.
# Generate with: openssl rand -hex 32
EDPROOF_HMAC_SECRET=

MAILBOX_PRICE_CENTS=299
POLAR_SERVER_URL=https://api.polar.sh
POLAR_PRODUCT_ID=01f68f36-4b6f-402a-b670-c7ebde03a836
POLAR_SUCCESS_URL=http://localhost:8080/v1/payments/polar/success?checkout_id={CHECKOUT_ID}
POLAR_RETURN_URL=http://localhost:8080
POLAR_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:8080/payment/success
STRIPE_CANCEL_URL=http://localhost:8080/payment/cancel

# Set Polar values to enable the preferred real checkout flow.
POLAR_TOKEN=

# Legacy Stripe fallback.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Explicit notifier selection (recommended).
# Valid: unsend, resend, sendgrid, mailgun, log
# If unset, falls back to legacy cascade (deprecated).
NOTIFIER_PROVIDER=

# Unsend email notifier. Required when NOTIFIER_PROVIDER=unsend.
UNSEND_KEY=
UNSEND_BASE_URL=https://unsend.admin.lt/api
UNSEND_FROM_EMAIL=
UNSEND_FROM_NAME=MailService

# Resend email notifier. Required when NOTIFIER_PROVIDER=resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=MailService

# SendGrid email notifier. Required when NOTIFIER_PROVIDER=sendgrid.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=MailService

# Mailgun email notifier. Required when NOTIFIER_PROVIDER=mailgun.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=
MAILGUN_FROM_NAME=MailService
MAILGUN_BASE_URL=https://api.mailgun.net
